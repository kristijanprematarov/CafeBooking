@page
@model PrivacyModel
@{
    ViewData["Title"] = "About Us";
}
<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-8">
        <p class="lead">Welcome to Cafe Booking, your favorite neighborhood cafe!</p>

        <h3>Our Story</h3>
        <p>
            Founded in 2025, Cafe Booking started with a simple mission: serve exceptional coffee
            and create a welcoming space for our community. Whether you're here for a quick espresso
            or a leisurely brunch, we're dedicated to making your visit memorable.
        </p>

        <h3>What We Offer</h3>
        <ul>
            <li>Artisan coffee roasted locally</li>
            <li>Fresh pastries baked daily</li>
            <li>Healthy breakfast and lunch options</li>
            <li>Free WiFi and cozy seating</li>
            <li>Online table reservations (coming soon!)</li>
        </ul>

        <h3>Visit Us</h3>
        <address>
            <strong>Location:</strong> 123 Main Street, Seattle, WA 98101<br />
            <strong>Hours:</strong> Monday-Friday 7am-7pm, Saturday-Sunday 8am-8pm<br />
            <strong>Phone:</strong> (206) 555-CAFE<br />
            <strong>Email:</strong> hello@cafebooking.com
        </address>
    </div>
    <div class="col-md-4">
        <div class="alert alert-info">
            <h5>Course Note</h5>
            <p>
                This is a demo application for learning Azure App Services deployment.
                In later modules, we'll add:
            </p>
            <ul class="small">
                <li>Database integration</li>
                <li>Online booking forms</li>
                <li>User authentication</li>
                <li>Email notifications</li>
            </ul>
        </div>
    </div>
</div>
